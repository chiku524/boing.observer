# Boing Network RPC endpoints (HTTP POST, JSON-RPC 2.0).
# No auth — public read-only RPC.
# Canonical contract: boing.network docs/THREE-CODEBASE-ALIGNMENT.md

# Testnet — public RPC (trailing slash optional; app normalizes)
NEXT_PUBLIC_TESTNET_RPC=https://testnet-rpc.boing.network/

# Mainnet — leave UNSET until a distinct mainnet JSON-RPC URL is published.
# Do not point this at testnet; the UI enables mainnet only when this differs from testnet.
# NEXT_PUBLIC_MAINNET_RPC=

# GitHub owner/repo for protocol docs + canonical QA JSON links on /qa (default: chiku524/boing.network)
# NEXT_PUBLIC_BOING_PROTOCOL_DOCS_REPO=chiku524/boing.network

# Optional: Search engine verification (Google Search Console, Bing Webmaster Tools)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code
